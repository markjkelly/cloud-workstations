#!/usr/bin/env bash
# ws-resolution — set Sway HEADLESS-1 output resolution and persist it
# Usage: ws-resolution [WxH]
#   ws-resolution 1920x1080   — set FHD resolution
#   ws-resolution 2560x1440   — set QHD resolution
#   ws-resolution              — show current / persisted resolution
#
# The chosen resolution is written to ~/.config/ws-resolution (plain WxH
# string). On the next boot, 08-workspaces.sh reads this file after Sway
# is confirmed running and restores it via swaymsg.
set -euo pipefail

RESOLUTION="${1:-}"
PERSIST_FILE="$HOME/.config/ws-resolution"

if [[ -z "$RESOLUTION" ]]; then
    echo "Usage: ws-resolution <WxH>  (e.g. ws-resolution 1920x1080)"
    echo ""
    if [[ -f "$PERSIST_FILE" ]]; then
        echo "Current persisted resolution: $(cat "$PERSIST_FILE")"
    else
        echo "No persisted resolution (default Sway output will be used)."
    fi
    echo ""
    echo "Current Sway outputs:"
    swaymsg -t get_outputs 2>/dev/null \
        | grep -E '"name"|"current_mode"' || echo "  (sway not running)"
    exit 0
fi

# Validate WxH format
if ! [[ "$RESOLUTION" =~ ^[0-9]+x[0-9]+$ ]]; then
    echo "Error: resolution must be WxH format (e.g. 1920x1080)" >&2
    exit 1
fi

WIDTH="${RESOLUTION%x*}"
HEIGHT="${RESOLUTION#*x}"

echo "Setting HEADLESS-1 output to ${WIDTH}x${HEIGHT}..."
swaymsg "output HEADLESS-1 resolution ${WIDTH}x${HEIGHT}"

mkdir -p "$(dirname "$PERSIST_FILE")"
echo "$RESOLUTION" > "$PERSIST_FILE"
echo "Persisted to $PERSIST_FILE — will restore on next boot."
